# Supabase PostgreSQL connection string format:
# postgres://postgres.PROJECT_REF:ENCODED_PASSWORD@POOLER_HOST:6543/postgres?sslmode=require
#
# Notes:
# - Use the Transaction Pooler connection from Supabase, not the Supabase project API URL.
# - The username must usually be postgres.PROJECT_REF.
# - URL encode the database password before placing it in DATABASE_URL.
#   Example: # -> %23, + -> %2B, ! -> %21, @ -> %40, : -> %3A
NODE_ENV=production
PORT=10000
DATABASE_URL=postgres://postgres.PROJECT_REF:ENCODED_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_SSL=true
# Supabase pooler + Render için false bırak.
# true yaparsan managed cert zincirinde SELF_SIGNED_CERT_IN_CHAIN hatası alabilirsin.
DB_SSL_REJECT_UNAUTHORIZED=false
JWT_SECRET=change-me-with-32-plus-random-chars
CORS_ORIGIN=https://your-vercel-domain.vercel.app
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=change-me-secure-password
SEED_ADMIN_NAME=Yonetici
